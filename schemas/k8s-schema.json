{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PingPongKong K8s Matrix Schema",
  "type": "object",
  "required": ["version", "cluster", "topology", "matrix"],
  "additionalProperties": false,
  "properties": {
    "version": { 
      "type": "string" 
    },
    "cluster": { 
      "type": "string" 
    },
    "topology": {
      "type": "object",
      "required": ["roles"],
      "additionalProperties": false,
      "properties": {
        "roles": { 
          "type": "object", 
          "additionalProperties": { "type": "string" },
          "minProperties": 1
        }
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "ports", "proto"],
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" },
              "ports": {
                "type": "array",
                "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "minItems": 1
              },
              "proto": { "type": "string", "enum": ["tcp", "udp", "icmp"] }
            }
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "from", "endpoint", "proto"],
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "name": { "type": "string" },
              "from": { "type": "string" },
              "endpoint": { "type": "string" },
              "proto": { "type": "string", "enum": ["tcp", "udp", "icmp"] }
            }
          }
        }
      }
    }
  }
}